<?php
session_start();

if(!isset($_SESSION['user_id']) || $_SESSION['user_role'] != 'admin'){
 header("Location: ../login.php");
 exit();
}

include '../config.php';

function h($value){
 return htmlspecialchars($value, ENT_QUOTES, 'UTF-8');
}

$message = "";
$message_type = "";

if(isset($_POST['add_doctor'])){

 $doctor_name = trim($_POST['doctor_name']);
 $specialization = trim($_POST['specialization']);
 $phone = trim($_POST['phone']);

 if($doctor_name == "" || $specialization == "" || $phone == ""){
 $message = "يرجى تعبئة جميع الحقول المطلوبة";
 $message_type = "error";
 }else{

 $image = "";

 if(isset($_FILES['image']) && $_FILES['image']['name'] != ""){

 $image_name = $_FILES['image']['name'];
 $image_tmp = $_FILES['image']['tmp_name'];

 $image_ext = strtolower(pathinfo($image_name, PATHINFO_EXTENSION));
 $allowed = ['jpg', 'jpeg', 'png', 'webp'];

 if(in_array($image_ext, $allowed)){

 $new_image_name = time() . "_" . rand(1000,9999) . "." . $image_ext;
 $image_path = "../images/" . $new_image_name;

 if(move_uploaded_file($image_tmp, $image_path)){
 $image = $new_image_name;
 }else{
 $message = "فشل رفع الصورة";
 $message_type = "error";
 }

 }else{
 $message = "نوع الصورة غير مسموح. استخدمي jpg أو png أو webp";
 $message_type = "error";
 }

 }else{
 $message = "يرجى اختيار صورة للطبيب";
 $message_type = "error";
 }

 if($message == ""){

 $stmt = mysqli_prepare(
 $conn,
 "INSERT INTO doctors (doctor_name, specialization, phone, image) 
 VALUES (?, ?, ?, ?)"
 );

 mysqli_stmt_bind_param($stmt, "ssss", $doctor_name, $specialization, $phone, $image);

 if(mysqli_stmt_execute($stmt)){
 header("Location: manage_doctors.php");
 exit();
 }else{
 $message = "حدث خطأ أثناء إضافة الطبيب";
 $message_type = "error";
 }
 }
 }
}
